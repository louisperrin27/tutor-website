# ============================================
# Environment Variables Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it contains secrets)
#
# To use: cp .env.example .env
# Then edit .env with your actual values
# ============================================

# --------------------------------------------
# Email Configuration (SMTP)
# --------------------------------------------
# These are used for sending emails via SMTP (contact form, booking confirmations, etc.)
# The example below uses iCloud Mail SMTP, but you can use any SMTP provider

# SMTP email address (the email account that will send emails)
# Example: your-email@icloud.com or your-email@gmail.com
EMAIL_USER=your-email@example.com

# SMTP password (use an app-specific password if your email provider requires it)
# For iCloud: Generate an app-specific password at appleid.apple.com
# For Gmail: Enable 2FA and generate an app password at myaccount.google.com/apppasswords
EMAIL_PASS=your-app-specific-password-here

# Destination email address (where contact form submissions and notifications are sent)
# This is typically your personal/business email inbox
EMAIL_TO=your-inbox@example.com

# --------------------------------------------
# Stripe Payment Configuration
# --------------------------------------------
# Required for processing payments through Stripe Checkout
# Get these from: https://dashboard.stripe.com/apikeys

# Stripe Secret Key (starts with sk_live_ for production or sk_test_ for testing)
# Use test keys during development, live keys in production
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Webhook Secret (for verifying webhook signatures)
# Get this from: https://dashboard.stripe.com/webhooks
# After creating a webhook endpoint, copy the "Signing secret"
# Format: whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

SESSION_SECRET=your-random-secret-key-change-this-in-production

# --------------------------------------------
# Admin Authentication
# --------------------------------------------
# Secret key required to access admin endpoints (slot generation, booking management)
# Use a strong, random string (at least 32 characters recommended)
# Generate one with: openssl rand -hex 32
ADMIN_KEY=your-secure-random-admin-key-here-minimum-32-characters


# --------------------------------------------
# Server Configuration (Optional)
# --------------------------------------------
# These have sensible defaults and are optional to set

# Server port (defaults to 3000 if not set)
# PORT=3000

# Node environment (development, production, etc.)
# Affects error handling and logging verbosity
# NODE_ENV=development

# Logging level (DEBUG, INFO, WARN, ERROR)
# DEBUG: All logs including detailed debugging information
# INFO: General information, warnings, and errors (default)
# WARN: Only warnings and errors
# ERROR: Only errors
# LOG_LEVEL=INFO

# ============================================
# Setup Instructions
# ============================================
#
# 1. Copy this file: cp .env.example .env
# 2. Fill in all required values above
# 3. For email setup:
#    - iCloud: Use your iCloud email and generate an app-specific password
#    - Gmail: Enable 2FA and create an app password
#    - Other providers: Check their SMTP settings documentation
# 4. For Stripe:
#    - Sign up at https://stripe.com
#    - Get API keys from dashboard
#    - Set up webhook endpoint pointing to: https://yourdomain.com/stripe/webhook
#    - Copy the webhook signing secret
# 5. Generate a secure admin key:
#    - Run: openssl rand -hex 32
#    - Or use an online generator (ensure it's at least 32 characters)
# 6. Never commit .env to git (it's already in .gitignore)
# 7. Restart your server after making changes
#
# ============================================

# Application Base URL (for password reset links)
# In production, set this to your domain (e.g., https://louisperrintutor.com)
# Leave empty in development to auto-detect from request headers
APP_BASE_URL=

# --------------------------------------------
# YouTube (optional – for index.html “latest video”)
# --------------------------------------------
# If the latest-video section shows “Unable to load”, set your channel ID here.
# Find it: open https://www.youtube.com/@YourHandle → View page source → search for "channelId" (starts with UC…)
# Example: YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxxxxxxxxxxx
# YOUTUBE_CHANNEL_ID=
